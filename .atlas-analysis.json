  "keyFeatures": [
    "PII detection in text using NLP (spaCy, Transformers, Stanza) and pattern matching",
    "PII anonymization with multiple operators: replace, redact, mask, hash, encrypt",
    "Image PII redaction including DICOM medical images using OCR",
    "Structured and semi-structured data anonymization (JSON, pandas DataFrames)",
    "40+ built-in recognizers for global and country-specific PII entities",
    "Extensible with custom recognizers and anonymization operators",
    "Multi-language support for PII detection",
    "REST API via Flask and Docker container deployment",
    "Batch processing for large-scale anonymization workloads",
    "Deanonymization support for reversible operations (e.g., decrypt)"
  ],
  "publicApiSurface": [
    "AnalyzerEngine.analyze(text, entities, language)",
    "BatchAnalyzerEngine.analyze_iterator(texts, language)",
    "AnonymizerEngine.anonymize(text, analyzer_results, operators)",
    "DeanonymizeEngine.deanonymize(text, entities, operators)",
    "BatchAnonymizerEngine.anonymize_list(texts, analyzer_results_list)",
    "PatternRecognizer(supported_entities, patterns, context)",
    "EntityRecognizer.analyze(text, entities)",
    "RecognizerRegistry.add_recognizer(recognizer)",
    "AnalyzerEngineProvider(conf_file)",
    "ImageRedactorEngine.redact(image, fill)",
    "DicomImageRedactorEngine.redact(image, fill)",
    "StructuredEngine.anonymize(data, operators, data_processor)",
    "LMRecognizer(supported_entities, model)",
    "LemmaContextAwareEnhancer(context_similarity_factor, min_score_with_context_similarity)"
  ]
